
a.out                               # С исполняемый файл g++
*.out                               # Другие исполняемые файлы с расширением .out
*.exe                               # Исполняемые файлы Windows (если компилируете под них)
*.o                                 # Объектные файлы (.cpp -> .o)
*.obj                               # Объектные файлы Windows
*.a                                 # Статические библиотеки (.a)
*.so                                # Динамические библиотеки Linux (.so)
*.dll                               # Динамические библиотеки Windows (.dll)
*.dylib                             # Динамические библиотеки macOS (.dylib)



build/                              # Стандартная папка для сборки CMake
cmake-build-*/                      # Папки сборки CL-build-debug и т.д.)
out/                                # Папка сборки (иногда используется)
bin/                                # Папка для исполняемых файлов
dist/                               # Папка для финальных релизов
install/                            # Папка установки (если используется)



*.log                               # Файлы логов
*.tmp                               # Временные файлы
*.temp                              # Временные файлы (альтернатива)
*.swp                               # Временные файлы Vim
*.swo                               # Вторичные временные файлы Vim
*~                                  # Временные файлы Vim (тильда)
.DS_Store                           # Служебный файл macOS
Thumbs.db                           # Служебный файл Windows
.directory                          # Служебный файл Midnight Commander
*.bak                               # Файлы резервных копий
*.backup                            # Файлы резервных копий (альтернатива)


.vscode/                            # Настройки VS Code (не всегда нужно, см. ниже)
.idea/                              # Настройки CLion, IntelliJ и других Jetbrains IDE
*.sublime-project                   # Настройки Sublime Text
*.sublime-workspace                 # Рабочая область Sublime Text
nbproject/                          # Настройки NetBeans
*.kateproj                          # Настройки Kate
.vs/                                # Настройки Visual Studio (Windows)
.eclipse/                           # Настройки Eclipse



.git/config.user                    # Пример локального файла настроек (если используется)
.git-blame-ignore-revs              # Для git blame



CMakeCache.txt                      # Кэш CMake
CMakeFiles/                         # Внутренние файлы CMake
cmake_install.cmake                 # Скрипт установки
Makefile                            # Сгенерированный Makefile
cm                                  # Скрипт установки
install_manifest.txt                # Список установленных файлов
compile_commands.json               # Команды компиляции (для IDE и стат. анализаторов)
Testing/                            # Результаты тестов CTest
CTestTestfile.cmake                 # Файл описания тестов CTest
dartConfiguration.tcl               # Конфигурация тестирования Dart (CMak  


*.gdb_history                       # История команд GDB
vgcore.*                            # Файлы дампа Valgrind
*.valgrind                          # Временные файлы Valgrind (если создаются)
.DS_Store                           # Повторно (на всякий случай)



venv/                               # Python virtual environment
env/                                # Python virtual environment (альтернатива)
.venv/                              # Python virtual environment (альтернатива)
node_modules/                       # Node.js dependencies
__pycache__/                        # Кэш Python
*.pyc                               # Компилированные файлы Python
*.egg-info/                         # Информация о пакете Python

